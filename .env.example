PORT=3000
HOST=localhost

MONGODB_URI2=mongodb://localhost:27017/despensarayana

JWT_SECRET=your_jwt_secret_here

# Email — compatible con cualquier proveedor SMTP (SendGrid, Resend, Gmail, Mailtrap)
# Mailtrap (desarrollo):  host=sandbox.smtp.mailtrap.io  port=587
# SendGrid (producción):  host=smtp.sendgrid.net         port=587  user=apikey
# Resend (producción):    host=smtp.resend.com           port=465  user=resend
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password_or_api_key
EMAIL_FROM=no-reply@despensa-rayana.com

# Cloudinary — subida de imágenes de productos
# Obtén estas credenciales en https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
