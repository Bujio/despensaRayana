NODE_ENV=development
PORT=3000
HOST=localhost

# Frontend origins allowed by CORS. Use comma-separated values for multiple origins.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
CLIENT_URL=http://localhost:5173
CORS_CREDENTIALS=false

# Request size and rate limit controls
JSON_BODY_LIMIT=100kb
URLENCODED_BODY_LIMIT=50kb
API_RATE_LIMIT=300

# MongoDB. Prefer MONGODB_URI for Atlas and MONGODB_URI2 for local development.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/despensarayana
MONGODB_URI2=mongodb://localhost:27017/despensarayana

# Use a strong random value of at least 32 characters.
JWT_SECRET=replace_with_a_long_random_secret_of_32_chars_minimum

# Email — compatible with SMTP providers such as Mailtrap, SendGrid or Resend.
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password_or_api_key
EMAIL_FROM=no-reply@despensa-rayana.com

# Public frontend URL used in account emails.
APP_BASE_URL=http://localhost:5173

# Public API URL used to build local upload URLs when Cloudinary is not configured.
API_BASE_URL=http://localhost:3000

# Cloudinary — optional. Local uploads are used when these placeholders remain.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
