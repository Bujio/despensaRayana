{
    "name": "despensa-rayana",
    "version": "1.0.0",
    "description": "tienda online de productos locales de la comarca de Valencia de Alcántara",
    "license": "ISC",
    "author": "Javier Vivas",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev": "node --watch index.js",
        "start": "node index.js",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit",
        "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
        "lint": "eslint .",
        "audit": "npm audit --audit-level=moderate",
        "seed:demo": "node scripts/seed-demo-data.js",
        "seed:demo-images": "node scripts/update-demo-product-images.js",
        "prepare": "husky"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "transform": {},
        "testTimeout": 30000
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cloudinary": "^2.10.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "mongodb": "^7.1.1",
        "mongoose": "^9.3.2",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "nodemailer": "^9.0.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "cross-env": "^10.1.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "mongodb-memory-server": "^11.0.1",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2"
    },
    "lint-staged": {
        "*.{js,ts,jsx,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css,html}": [
            "prettier --write"
        ]
    }
}
